#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path
from linux_backend import LinuxBackend
from mac_backend import MacBackend
from utils import Scope, eprint, is_admin_windows, is_root_unix, logger, platform, resolve_command_parts, setup_logging
from windows_backend import WindowsBackend


def require_command(command_parts: list[str]) -> None:
    if not command_parts:
        raise SystemExit("Missing COMMAND after --")


def ensure_scope_allowed(scope: Scope) -> None:
    if platform() == "win":
        if not is_admin_windows():
            raise SystemExit("Windows only supports admin execution for uniservice.")
        return

    if scope.value == "system" and not is_root_unix():
        raise SystemExit("--system requires root.")


def get_backend(scope: Scope):
    p = platform()
    if p == "linux":
        return LinuxBackend(scope)
    if p == "mac":
        return MacBackend(scope)
    if p == "win":
        return WindowsBackend(scope)
    raise SystemExit("Unsupported platform.")


def add_scope_args(parser: argparse.ArgumentParser) -> None:
    scope = parser.add_mutually_exclusive_group()
    scope.add_argument("--system", action="store_true", help="system scope (requires root on mac/linux)")
    scope.add_argument("--user", action="store_true", help="current user scope (default on mac/linux)")


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(prog="uniservice", add_help=True)
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_list = sub.add_parser("list")
    add_scope_args(p_list)

    p_cat = sub.add_parser("cat")
    add_scope_args(p_cat)
    p_cat.add_argument("--name", required=True, help="service name")

    p_enable = sub.add_parser("enable")
    add_scope_args(p_enable)
    p_enable.add_argument("--name", required=True, help="service name")

    p_disable = sub.add_parser("disable")
    add_scope_args(p_disable)
    p_disable.add_argument("--name", required=True, help="service name")

    p_start = sub.add_parser("start")
    add_scope_args(p_start)
    p_start.add_argument("--name", required=True, help="service name")

    p_stop = sub.add_parser("stop")
    add_scope_args(p_stop)
    p_stop.add_argument("--name", required=True, help="service name")

    p_remove = sub.add_parser("remove")
    add_scope_args(p_remove)
    p_remove.add_argument("--name", required=True, help="service name")

    p_add = sub.add_parser("add")
    add_scope_args(p_add)
    p_add.add_argument("--name", required=True, help="service name")
    p_add.add_argument(
        "--workdir",
        default="",
        help="working directory for the service (default: current dir)",
    )
    p_add.add_argument("remainder", nargs=argparse.REMAINDER)

    return parser.parse_args(argv)


def normalize_command_parts(remainder: list[str]) -> list[str]:
    if not remainder:
        return []
    if remainder[0] == "--":
        return remainder[1:]
    return remainder


def main(argv: list[str]) -> int:
    setup_logging()
    args = parse_args(argv)
    scope = Scope.from_args(args)
    backend = get_backend(scope)

    if args.cmd == "list":
        ensure_scope_allowed(scope)
        logger.info("cmd=list")
        rows = backend.list_info()
        print("NAME\tENABLED\tRUNNING")
        for r in rows:
            if r.enabled is True:
                enabled = "yes"
            elif r.enabled is False:
                enabled = "no"
            else:
                enabled = "?"

            if r.running is True:
                running = "yes"
            elif r.running is False:
                running = "no"
            else:
                running = "?"

            print(f"{r.name}\t{enabled}\t{running}")
        return 0

    if args.cmd == "cat":
        ensure_scope_allowed(scope)
        logger.info("cmd=cat name=%s", args.name)
        backend.cat(args.name)
        return 0

    if args.cmd == "enable":
        ensure_scope_allowed(scope)
        if not backend.exists(args.name):
            raise SystemExit(f'Service "{args.name}" not found.')
        logger.info("cmd=enable name=%s", args.name)
        backend.enable(args.name)
        print(f'OK: enabled "{args.name}"')
        return 0

    if args.cmd == "disable":
        ensure_scope_allowed(scope)
        if not backend.exists(args.name):
            raise SystemExit(f'Service "{args.name}" not found.')
        logger.info("cmd=disable name=%s", args.name)
        backend.disable(args.name)
        print(f'OK: disabled "{args.name}"')
        return 0

    if args.cmd == "start":
        ensure_scope_allowed(scope)
        if not backend.exists(args.name):
            raise SystemExit(f'Service "{args.name}" not found.')
        logger.info("cmd=start name=%s", args.name)
        backend.start(args.name)
        print(f'OK: started "{args.name}"')
        return 0

    if args.cmd == "stop":
        ensure_scope_allowed(scope)
        if not backend.exists(args.name):
            raise SystemExit(f'Service "{args.name}" not found.')
        logger.info("cmd=stop name=%s", args.name)
        backend.stop(args.name)
        print(f'OK: stopped "{args.name}"')
        return 0

    if args.cmd == "remove":
        ensure_scope_allowed(scope)
        if not backend.exists(args.name):
            raise SystemExit(f'Service "{args.name}" not found.')
        logger.info("cmd=remove name=%s", args.name)
        backend.stop(args.name)
        backend.disable(args.name)
        backend.remove(args.name)
        print(f'OK: removed "{args.name}"')
        return 0

    if args.cmd == "add":
        ensure_scope_allowed(scope)
        logger.info("cmd=add name=%s", args.name)
        cmd_parts = normalize_command_parts(args.remainder)
        require_command(cmd_parts)
        cmd_parts = resolve_command_parts(cmd_parts)
        if not args.workdir:
            logger.warning("No --workdir provided; command runs in current directory: %s", Path.cwd())
        wd = Path(args.workdir) if args.workdir else Path.cwd()
        if backend.exists(args.name):
            if sys.stdin.isatty():
                answer = input(f'Service "{args.name}" already exists. Overwrite? [y/N] ').strip().lower()
                if answer not in {"y", "yes"}:
                    raise SystemExit("Aborted.")
            else:
                raise SystemExit(f'Service "{args.name}" already exists. Run in an interactive terminal to confirm overwrite.')
            backend.stop(args.name)
            backend.disable(args.name)
            backend.remove(args.name)
        backend.create(args.name, wd, cmd_parts)
        backend.enable(args.name)
        backend.start(args.name)
        print(f'OK: added "{args.name}"')
        return 0

    raise SystemExit("Unknown command.")


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv[1:]))
    except BrokenPipeError:
        raise
    except subprocess.CalledProcessError as ex:
        eprint(f"FAIL: command failed ({ex.returncode}): {' '.join(ex.cmd)}")
        raise SystemExit(ex.returncode)
    except SystemExit as ex:
        code = ex.code
        if code is None:
            raise
        if isinstance(code, int):
            raise
        msg = str(code).strip()
        if msg:
            eprint(f"FAIL: {msg}")
        raise SystemExit(1)
    except Exception as ex:
        eprint(f"FAIL: {type(ex).__name__}: {ex}")
        raise SystemExit(1)
